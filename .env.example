# Groq (remote AI). Server reads GROQ_API_KEY or VITE_GROQ_API_KEY — use either.
# Create a key at https://console.groq.com (free tier).
GROQ_API_KEY=
# VITE_GROQ_API_KEY=

# Sepolia Testnet Configuration
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
SEPOLIA_PRIVATE_KEY=YOUR_WALLET_PRIVATE_KEY

# Monad Testnet (chain id 10143) — deploy soulbound contract
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_TESTNET_PRIVATE_KEY=YOUR_WALLET_PRIVATE_KEY
# Skip Ignition “confirm deploy?” prompt (set to any value)
HARDHAT_IGNITION_CONFIRM_DEPLOYMENT=1

# After deploy: point the Vite app at the contract
VITE_WRITING_DNA_SOULBOUND_ADDRESS=0xYourDeployedContract

# Style leaderboard (StyleLeaderboard.sol)
# npm run deploy:leaderboard  (+ MONAD_TESTNET_PRIVATE_KEY, HARDHAT_IGNITION_CONFIRM_DEPLOYMENT=1)
VITE_STYLE_LEADERBOARD_ADDRESS=0xYourLeaderboardContract
# Sample rows in UI (default on). Set to false for on-chain rows only.
VITE_STYLE_LEADERBOARD_DEMO=true
